{
  "name": "bigdata-aplicado-quiz",
  "version": "1.0.0",
  "description": "Estudio de preguntas Big Data Aplicado con repetición espaciada",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "build:vite": "vite build",
    "build:electron": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "electron-store": "^7.0.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.bigdata.aplicado.quiz",
    "productName": "BigData Aplicado Quiz",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "electron/**/*", "node_modules/**/*", "package.json"],
    "win": { "target": [{ "target": "nsis", "arch": ["x64"] }] },
    "mac": { "target": [{ "target": "dmg", "arch": ["x64"] }] },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true }
  }
}
